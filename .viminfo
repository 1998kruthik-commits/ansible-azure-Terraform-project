	---
	- name: Demonstrate Always and Never Tags
	  hosts: webservers
	
	  tasks:
	
	    - name: Always Task
	      debug:
	        msg: "I always run"
	      tags:
	        - always
	
	    - name: Normal Task
	      debug:
	        msg: "I am a normal task"
	      tags:
	        - normal
	
	    - name: Never Task
	      debug:
	        msg: "I run only when requested"
	      tags:
	        - never
